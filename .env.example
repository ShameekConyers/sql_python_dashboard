FRED_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# --- Agent configuration (optional, for "Ask the Data" feature) ---
# AGENT_PROVIDER=ollama              # ollama | anthropic | openai (default: ollama)
# AGENT_MODEL=llama3.1:8b            # Model identifier for the chosen provider
# OPENAI_API_KEY=your_key_here       # Only needed if AGENT_PROVIDER=openai

# --- Streamlit Cloud secrets (.streamlit/secrets.toml) ---
# On Streamlit Cloud, paste secrets into the app's Secrets UI.
# See .streamlit/secrets.toml for the required format.
# Local Ollama usage requires no secrets.
